# Python / test cache
.pytest_cache/
__pycache__/
**/__pycache__/
*.pyc
*.py[cod]
*.egg-info/
layout_design.egg-info/
.venv/
venv/
.env

# Large / subject-specific inputs (keep structure via .gitkeep)
data/raw/*.stl
data/raw/*.ply
data/raw/*.obj
data/raw/*.mtl
data/raw/*_texture.png
data/raw/*_rgb.vtk
data/cleaned_scans/*.stl
data/cleaned_scans/*.ply
data/cleaned_scans/*.obj

# Generated pipeline artifacts
data/output/**/*
!data/output/**/.gitkeep
data/archive/**/*
!data/archive/**/.gitkeep
data/json/*.json
!data/json/.gitkeep
data/presets/*.json
!data/presets/.gitkeep
!data/presets/*.example.json
# Default assignment map shipped with the repo (required for `run` / synthesize)
!data/presets/subject1_best_v4.json

# Postprocess
data/output/smooth/*.json
data/output/matlab/*.mat
data/output/bundles/**/*
!data/output/bundles/**/.gitkeep
data/output/gcode/**/*
!data/output/gcode/**/.gitkeep
subject_optimized/

# Per-subject print registration (measured at print time)
config/postprocessor/subjects/subject_*.yaml
!config/postprocessor/subjects/example.yaml
!config/postprocessor/subjects/subject_synthetic.yaml

# IDE / OS
.idea/
.vscode/
Thumbs.db
Desktop.ini
*.log

# MATLAB g-code output (generated)
legacy_gcode_examples/**/*.txt
!legacy_gcode_examples/README.md
